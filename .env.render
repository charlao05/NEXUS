# ============================================================
# NEXUS — Variáveis SECRETAS para o Render
# ============================================================
# Preencha cada valor abaixo e adicione no painel do Render:
#   Dashboard → nexxusapp-backend → Environment → Add Environment Variable
#
# ⚠️  NÃO COMMITE ESTE ARQUIVO no Git depois de preenchido.
# ============================================================

# ── 1. OPENAI ────────────────────────────────────────────────
# Painel: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-COLE_AQUI

# ── 2. JWT SECRET ────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=COLE_AQUI_O_TOKEN_GERADO

# ── 3. STRIPE ────────────────────────────────────────────────
# Painel: https://dashboard.stripe.com/apikeys
# Use sk_live_ em produção (não sk_test_)
STRIPE_SECRET_KEY=sk_live_COLE_AQUI
STRIPE_PUBLISHABLE_KEY=pk_live_COLE_AQUI

# Painel Stripe → Developers → Webhooks → seu webhook → Signing secret
# URL do webhook: https://api.nexxusapp.com.br/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_COLE_AQUI

# Painel Stripe → Products → cada plano → copie o Price ID (price_xxx)
STRIPE_PRICE_ESSENCIAL=price_COLE_AQUI
STRIPE_PRICE_PROFISSIONAL=price_COLE_AQUI
STRIPE_PRICE_COMPLETO=price_COLE_AQUI

# ── 4. GOOGLE OAUTH ──────────────────────────────────────────
# Painel: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=COLE_AQUI.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-COLE_AQUI
GOOGLE_REDIRECT_URI=https://api.nexxusapp.com.br/api/auth/google/callback

# ── 5. RESEND (email) ────────────────────────────────────────
# Painel: https://resend.com/api-keys
RESEND_API_KEY=re_COLE_AQUI

# ── 6. TELEGRAM BOT ──────────────────────────────────────────
# Obtenha com @BotFather no Telegram: /newbot ou /mybots
TELEGRAM_BOT_TOKEN=COLE_AQUI
# Gere um token seguro: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=COLE_AQUI
# Seu chat_id pessoal (use @userinfobot no Telegram para descobrir)
TELEGRAM_ADMIN_CHAT_ID=COLE_AQUI

# ── 7. EMAIL DE ADMIN ────────────────────────────────────────
ADMIN_EMAIL=appnexxus.app@gmail.com
