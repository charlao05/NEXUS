# ============================================================
# NEXUS — Template de Variáveis de Ambiente
# ============================================================
#
# ⚠️  COMO USAR:
#     1. Copie para backend/.env:  cp .env.template backend/.env
#     2. Preencha CADA campo com suas credenciais reais
#     3. NUNCA commite o arquivo .env — está no .gitignore
#
# ⚠️  SEGURANÇA:
#     - Nunca compartilhe este arquivo com credenciais preenchidas
#     - Nunca exponha chaves em issues, PRs, Slack ou e-mail
#     - Rotacione credenciais imediatamente se suspeitar de vazamento
#     - Use variáveis de ambiente no servidor (Render, Railway, etc.)
#       em vez de arquivos .env em produção
#
# ============================================================

# ============================================================
# 1. AMBIENTE
# ============================================================
ENVIRONMENT=development
# ENVIRONMENT=production   ← altere apenas no servidor de produção

# ============================================================
# 2. JWT / AUTENTICAÇÃO
# ============================================================
# Gere um secret seguro com: openssl rand -hex 64
JWT_SECRET=GERE_COM_openssl_rand_-hex_64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# ============================================================
# 3. DATABASE
# ============================================================
# Desenvolvimento (SQLite):
DATABASE_URL=sqlite:///./nexus.db
# Produção (PostgreSQL):
# DATABASE_URL=postgresql://usuario:senha@host:5432/nexus

# ============================================================
# 4. OPENAI / LLM
# ============================================================
# Obtenha em: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-COLE_SUA_CHAVE_AQUI
OPENAI_MODEL=gpt-4.1

# ============================================================
# 5. STRIPE / PAGAMENTOS
# ============================================================
# Dashboard: https://dashboard.stripe.com/apikeys
# Teste:     sk_test_ / pk_test_
# Produção:  sk_live_ / pk_live_   ← nunca commite chaves live!
STRIPE_SECRET_KEY=sk_test_COLE_SUA_CHAVE_SECRETA_AQUI
STRIPE_PUBLISHABLE_KEY=pk_test_COLE_SUA_CHAVE_PUBLICA_AQUI
STRIPE_WEBHOOK_SECRET=whsec_COLE_SEU_WEBHOOK_SECRET_AQUI
# Price IDs dos planos (criados no Stripe Dashboard → Products → Prices)
# Essencial R$29,90/mês | Profissional R$59,90/mês | Completo R$89,90/mês
STRIPE_PRICE_ESSENCIAL=price_COLE_O_ID_AQUI
STRIPE_PRICE_PROFISSIONAL=price_COLE_O_ID_AQUI
STRIPE_PRICE_COMPLETO=price_COLE_O_ID_AQUI

# ============================================================
# 6. GOOGLE OAUTH 2.0  (login com Google)
# ============================================================
# Console: https://console.cloud.google.com/apis/credentials
# Conta recomendada: appnexxus.app@gmail.com
# Tipo de credencial: "OAuth 2.0 Client ID" → Web Application
GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-SEU_SECRET_AQUI
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
VITE_GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com

# ============================================================
# 7. FACEBOOK OAUTH 2.0  (login com Facebook)
# ============================================================
# Console: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=SEU_APP_ID_AQUI
FACEBOOK_CLIENT_SECRET=SEU_APP_SECRET_AQUI
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8000/api/auth/facebook/callback

# ============================================================
# 8. REDIS  (cache e rate limiting)
# ============================================================
# Deixe vazio para usar fallback in-memory (dev)
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# 9. EMAIL  (Resend)
# ============================================================
# Obtenha em: https://resend.com/api-keys
# RESEND_API_KEY=re_COLE_SUA_CHAVE_AQUI
# EMAIL_FROM=NEXUS <noreply@nexus.app>

# ============================================================
# 10. MONITORAMENTO  (Sentry)
# ============================================================
# SENTRY_DSN=https://SEU_DSN@sentry.io/SEU_PROJECT_ID
# SENTRY_RELEASE=nexus@1.0.0

# ============================================================
# 11. ADMIN SEED
# ============================================================
# E-mails que receberão role=admin automaticamente no startup
# ADMIN_EMAILS=appnexxus.app@gmail.com

# ============================================================
# 12. CORS / URLS
# ============================================================
# CORS_ORIGINS=https://nexus.app
# FRONTEND_URL=https://nexus.app
# BACKEND_BASE_URL=https://api.nexus.app

# ============================================================
# 13. BROWSER / PLAYWRIGHT
# ============================================================
DEFAULT_BROWSER=chromium
# BROWSER_HEADLESS=true

# ============================================================
# 14. INTEGRAÇÕES GOVERNAMENTAIS (Brasil)
# ============================================================
# CND_PROVIDER=mock
# CND_API_KEY=
# DIVIDA_ATIVA_PROVIDER=mock
# DIVIDA_ATIVA_API_KEY=
# TRANSPARENCIA_API_KEY=
# NFSE_AGGREGATOR_PROVIDER=focus_nfe
# NFSE_AGGREGATOR_API_KEY=
# NFSE_NACIONAL_TOKEN=
# NFSE_NACIONAL_BASE_URL=

# ============================================================
# 15. TELEGRAM BOT
# ============================================================
# Crie seu bot em: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI
# TELEGRAM_BOT_USERNAME=nexusapp_bot
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_ADMIN_CHAT_ID=

# ============================================================
# 16. GOOGLE CALENDAR / GMAIL  (Service Account)
# ============================================================
# GOOGLE_SERVICE_ACCOUNT_FILE=config/sa-key.json
# GOOGLE_CALENDAR_ID=primary
# GMAIL_DELEGATED_USER=

# ============================================================
# 17. DOCKER / POSTGRES  (docker-compose)
# ============================================================
# POSTGRES_USER=nexus
# POSTGRES_PASSWORD=SENHA_FORTE_AQUI
# POSTGRES_DB=nexus
