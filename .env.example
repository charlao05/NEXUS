# ============================================================
# NEXUS — Template de Variáveis de Ambiente
# ============================================================
# ⚠️  Copie este arquivo para .env e preencha com credenciais reais
#     cp .env.example .env
# ⚠️  NUNCA commit .env no Git — está protegido em .gitignore
# ============================================================

# ===== 1. CORE / APLICAÇÃO =====
ENVIRONMENT=development
# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:5173
# FRONTEND_URL=https://nexus.onrender.com
# BACKEND_BASE_URL=http://127.0.0.1:8000

# ===== 2. JWT / AUTENTICAÇÃO =====
JWT_SECRET=TROQUE_PARA_UM_SECRET_SEGURO_AQUI
JWT_ALGORITHM=HS256

# ===== 3. DATABASE =====
# Dev (SQLite): usar caminho absoluto
DATABASE_URL=sqlite:///C:/Users/<seu_usuario>/Desktop/NEXUS/backend/test.db
# Prod (PostgreSQL): descomentar abaixo
# DATABASE_URL=postgresql://user:password@host:5432/nexus

# ===== 4. OPENAI / LLM =====
# Obtenha em: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_MODEL=gpt-4.1

# ===== 5. STRIPE / PAGAMENTOS =====
# Obtenha em: https://dashboard.stripe.com/apikeys
# Modo TESTE: sk_test_ / pk_test_   Modo PROD: sk_live_ / pk_live_
# ⚠️ NUNCA compartilhe ou exponha as chaves live!
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ===== 6. GOOGLE OAUTH =====
# Console: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# ===== 7. FACEBOOK OAUTH =====
# Console: https://developers.facebook.com/apps/
# FACEBOOK_CLIENT_ID=xxxxx
# FACEBOOK_CLIENT_SECRET=xxxxx
# FACEBOOK_REDIRECT_URI=http://127.0.0.1:8000/api/auth/facebook/callback

# ===== 8. REDIS =====
# Deixe vazio para usar fallback in-memory
# REDIS_URL=redis://localhost:6379/0

# ===== 9. EMAIL (Resend) =====
# Obtenha em: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=NEXUS <onboarding@resend.dev>

# ===== 10. MONITORAMENTO (Sentry) =====
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_RELEASE=nexus@0.4.0

# ===== 11. BROWSER / PLAYWRIGHT =====
DEFAULT_BROWSER=chromium
# BROWSER_HEADLESS=  (automático: headless em prod, headed em dev)
# BROWSER_CLOSE_DELAY=0

# ===== 12. INTEGRAÇÕES GOVERNAMENTAIS =====
# Provedores: mock (padrão para dev), infosimples, serpro, etc.
# CND_PROVIDER=mock
# CND_API_KEY=
# DIVIDA_ATIVA_PROVIDER=mock
# DIVIDA_ATIVA_API_KEY=
# TRANSPARENCIA_API_KEY=
# NFSE_AGGREGATOR_PROVIDER=focus_nfe
# NFSE_AGGREGATOR_API_KEY=
# NFSE_NACIONAL_TOKEN=
# NFSE_NACIONAL_BASE_URL=

# ===== 13. TELEGRAM BOT API =====
# Converse com @BotFather: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=xxxxx:xxxxx
# TELEGRAM_BOT_USERNAME=nexusapp_bot
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_ADMIN_CHAT_ID=

# ===== 14. GOOGLE CALENDAR / GMAIL (Service Account) =====
# GOOGLE_SERVICE_ACCOUNT_FILE=config/sa-key.json
# GOOGLE_CALENDAR_ID=primary
# GMAIL_SERVICE_ACCOUNT_FILE=
# GMAIL_DELEGATED_USER=
# GMAIL_CREDENTIALS_FILE=

# ===== 15. GOOGLE ADSENSE =====
# GOOGLE_ADSENSE_SA_KEY=config/adsense-sa-key.json
# GOOGLE_ADSENSE_ACCOUNT_ID=ca-pub-xxxxx
# GOOGLE_ADSENSE_CLIENT_ID=ca-pub-xxxxx

# ===== 16. DOCKER / POSTGRES (usado em docker-compose.yml) =====
# POSTGRES_USER=nexus
# POSTGRES_PASSWORD=nexus_secret
# POSTGRES_DB=nexus
